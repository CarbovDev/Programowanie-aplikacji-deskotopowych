<Window x:Class="Zadanie_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formularz Osobowy" Height="350" Width="450">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Podaj imię i nazwisko:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ImieNazwisko, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="24"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Podaj datę urodzenia:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DataUrodzin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="24" ToolTip="Np. 15.05.2000"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Twoje Pierwsze imię:" Margin="0,0,10,10"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PierwszeImie}" FontWeight="Bold" Foreground="Blue" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Twoje Nazwisko:" Margin="0,0,10,10"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Nazwisko}" FontWeight="Bold" Foreground="Blue" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Twój Wiek:" Margin="0,0,10,10"/>
        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Wiek}" FontWeight="Bold" Foreground="Red" Margin="0,0,0,10"/>
    </Grid>
</Window>