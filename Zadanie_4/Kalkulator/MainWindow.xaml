<Window x:Class="Kalkulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kalkulator"
        mc:Ignorable="d"
        Title="Kalkulator" Height="450" Width="800">
    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#FFD0AEAE" Padding="5">
            <WrapPanel Orientation="Horizontal" ItemWidth="80" ItemHeight="35">
                <Button Content="1/x" Click="OperatorJednoargumentowy_Click" Margin="2" Background="#EAEAEA"/>
                <Button Content="x^2" Click="OperatorJednoargumentowy_Click" Margin="2" Background="#EAEAEA"/>
                <Button Content="sqrt" Click="OperatorJednoargumentowy_Click" Margin="2" Background="#EAEAEA"/>
                <Button Content="%" Click="Procent_Click" Margin="2" Background="#EAEAEA"/>
                <Button Content="MC" Margin="2" Background="#DCDCDC"/>
                <Button Content="MR" Margin="2" Background="#DCDCDC"/>
                <Button Content="M+" Margin="2" Background="#DCDCDC"/>
                <Button Content="MS" Margin="2" Background="#DCDCDC"/>
            </WrapPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#EAEAEA" Padding="5">
            <StackPanel x:Name="PanelHistorii">
                <TextBlock Text="Historia operacji" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border BorderBrush="#FF931010" BorderThickness="1" Background="White" CornerRadius="20" Padding="5">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtFormula" Text="" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TxtResult" Text="0" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Content="CE" Grid.Row="0" Grid.Column="0" Click="CE_Click" Margin="2" Background="#FFCCCC"/>
                <Button Content="C" Grid.Row="0" Grid.Column="1" Click="C_Click" Margin="2" Background="#FF9999"/>
                <Button Content="⌫" Grid.Row="0" Grid.Column="2" Click="Backspace_Click" Margin="2"/>
                <Button Content="/" Grid.Row="0" Grid.Column="3" Click="OperatorDwuargumentowy_Click" Margin="2" Background="#F0F0F0" FontSize="16"/>

                <Button Content="7" Grid.Row="1" Grid.Column="0" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="8" Grid.Row="1" Grid.Column="1" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="9" Grid.Row="1" Grid.Column="2" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="*" Grid.Row="1" Grid.Column="3" Click="OperatorDwuargumentowy_Click" Margin="2" Background="#F0F0F0" FontSize="16"/>

                <Button Content="4" Grid.Row="2" Grid.Column="0" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="5" Grid.Row="2" Grid.Column="1" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="6" Grid.Row="2" Grid.Column="2" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="-" Grid.Row="2" Grid.Column="3" Click="OperatorDwuargumentowy_Click" Margin="2" Background="#F0F0F0" FontSize="16"/>

                <Button Content="1" Grid.Row="3" Grid.Column="0" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="2" Grid.Row="3" Grid.Column="1" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="3" Grid.Row="3" Grid.Column="2" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="+" Grid.Row="3" Grid.Column="3" Click="OperatorDwuargumentowy_Click" Margin="2" Background="#F0F0F0" FontSize="16"/>

                <Button Content="+/-" Grid.Row="4" Grid.Column="0" Click="Znak_Click" Margin="2"/>
                <Button Content="0" Grid.Row="4" Grid.Column="1" Click="Liczba_Click" Margin="2" FontSize="16" Background="White"/>
                <Button Content="," Grid.Row="4" Grid.Column="2" Click="Przecinek_Click" Margin="2"/>
                <Button Content="=" Grid.Row="4" Grid.Column="3" Click="Rownasie_Click" Margin="2" Background="#99FF99" FontSize="16" FontWeight="Bold"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
