<Window x:Class="Zadanie_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zadanie 1" Height="500" Width="800">

    <Grid Background="#F0F0F0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                      Margin="10,10,10,5">

            <StackPanel Orientation="Horizontal">
                <Border Width="200" Height="80" Background="#FFED6C6C" Margin="0,0,10,0"/>
                <Border Width="200" Height="80" Background="LightSeaGreen" Margin="0,0,10,0"/>
                <Border Width="200" Height="80" Background="LightSkyBlue" Margin="0,0,10,0"/>
                <Border Width="200" Height="80" Background="Gold" Margin="0,0,10,0"/>
                <Border Width="200" Height="80" Background="Plum" Margin="0,0,10,0"/>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Row="1" Grid.Column="0" 
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Margin="10,5,5,10">

            <StackPanel Orientation="Vertical">
                <Border Width="120" Height="100" Background="CadetBlue" Margin="0,0,0,10"/>
                <Border Width="120" Height="100" Background="DarkKhaki" Margin="0,0,0,10"/>
                <Border Width="120" Height="100" Background="IndianRed" Margin="0,0,0,10"/>
                <Border Width="120" Height="100" Background="MediumPurple" Margin="0,0,0,10"/>
                <Border Width="120" Height="100" Background="SteelBlue" Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" 
                Background="White" BorderBrush="DarkGray" BorderThickness="1"
                Margin="5,5,10,10">
            <TextBlock Text="Test" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" FontSize="16"/>
        </Border>

    </Grid>
</Window>
